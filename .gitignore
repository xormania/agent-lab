# Local env / secrets
.env
.env.*
!.env.example
!.env.*.example
*.local
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx
*.kdbx
*.age
*.gpg

# Runtime / generated data
data/
volumes/
runtime/
logs/
state/
cache/
.cache/
models/
browser-profiles/
agent-state/
.tmp/
# tmp/ holds generated audits, plans, and agent revisions (from tools/new-revision.sh etc.).
# These files frequently contain absolute host paths (e.g. /home/... or $HOME/projects/...)
# when written by tools or agents. Keep the dir via .gitkeep but ignore new contents.
tmp/
!tmp/.gitkeep
*.sqlite
*.db
*.log

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# Python / Node / general caches
__pycache__/
*.py[cod]
.pytest_cache/
node_modules/

# Docker compose override files may contain local paths or secrets
compose.override.yaml
compose.*.override.yaml

# Temp location for machine account token (used for xor-machine auth while commits appear as xormania)
# Will be deleted after setup. Never commit tokens.
/tmp/ignore/
