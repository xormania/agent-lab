#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)/common"

volumes=0

case "${1:-}" in
  "")
    ;;
  --volumes)
    volumes=1
    ;;
  -h|--help)
    printf 'Usage: %s [--volumes]\n' "$0"
    exit 0
    ;;
  *)
    printf 'Unknown option: %s\n' "$1" >&2
    printf 'Usage: %s [--volumes]\n' "$0" >&2
    exit 1
    ;;
esac

if [ "$#" -gt 1 ]; then
  printf 'Too many arguments\n' >&2
  printf 'Usage: %s [--volumes]\n' "$0" >&2
  exit 1
fi

agent_lab_require_env_file

down_args=(down)
[ "$volumes" -eq 1 ] && down_args+=(--volumes)

agent_lab_compose "${down_args[@]}"
